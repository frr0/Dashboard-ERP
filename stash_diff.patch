+// This function loads Grid.js from CDN if not already loaded
+function ensureGridJs(callback) {
+    if (typeof gridjs !== 'undefined') {
+        callback();
+        return;
+    }
+    var existingScript = document.querySelector('script[data-dynamic-gridjs]');
+    if (existingScript) {
+        existingScript.addEventListener('load', function() { callback(); });
+        return;
+    }
+    var script = document.createElement('script');
+    script.src = 'https://unpkg.com/gridjs/dist/gridjs.umd.js';
+    script.async = true;
+    script.defer = true;
+    script.dataset.dynamicGridjs = '1';
+    script.onload = function() { callback(); };
+    script.onerror = function() { console.error('Grid.js CDN non raggiungibile'); };
+    document.head.appendChild(script);
+}
 
